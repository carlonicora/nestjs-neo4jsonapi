{
  "name": "@carlonicora/nestjs-neo4jsonapi",
  "version": "1.101.0",
  "description": "NestJS foundation package with JSON:API, Neo4j, Redis, LangChain agents, and common utilities",
  "author": "Carlo Nicora",
  "license": "GPL-3.0-or-later",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "neo4jsonapi-migrate": "./dist/tools/migrate-entity/index.js",
    "generate-module": "./dist/scripts/generate-module/index.js",
    "generate-rbac-paths": "./dist/tools/generate-rbac-paths/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./common": {
      "types": "./dist/common/index.d.ts",
      "default": "./dist/common/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./core/*": {
      "types": "./dist/core/*.d.ts",
      "default": "./dist/core/*.js"
    },
    "./foundations": {
      "types": "./dist/foundations/index.d.ts",
      "default": "./dist/foundations/index.js"
    },
    "./foundations/*": {
      "types": "./dist/foundations/*.d.ts",
      "default": "./dist/foundations/*.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "default": "./dist/agents/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap/index.d.ts",
      "default": "./dist/bootstrap/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tools/migrate-entity/tsconfig.json && tsc -p tools/generate-rbac-paths/tsconfig.json && tsc -p scripts/generate-module/tsconfig.json && cp -R src/core/email/templates dist/core/email/",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" \"tools/**/*.spec.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:stripe": "vitest run --testPathPattern=stripe",
    "generate:rbac-paths": "node dist/tools/generate-rbac-paths/index.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@azure/storage-blob": "^12.31.0",
    "@kenjiuno/msgreader": "^1.28.0",
    "mailparser": "^3.9.11",
    "@getbrevo/brevo": "^5.0.4",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.48",
    "@langchain/google-vertexai": "^2.1.31",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-checkpoint-redis": "^1.0.7",
    "@langchain/openai": "^1.4.7",
    "@langchain/textsplitters": "^1.0.1",
    "langsmith": "^0.7.5",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.64.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sendgrid/mail": "^8.1.6",
    "@simplewebauthn/server": "^13.3.0",
    "adm-zip": "^0.5.17",
    "gray-matter": "^4.0.3",
    "mdast-util-mdx": "^3.0.0",
    "mdast-util-to-markdown": "^2.1.2",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "uuid": "^14.0.0",
    "ai": "^6.0.5",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.77.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "discord.js": "^14.26.4",
    "docx": "9.6.1",
    "docx-templates": "^4.15.0",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.8.5",
    "handlebars": "^4.7.9",
