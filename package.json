    "neo4j-driver": "^6.0.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-redoc": "^2.2.2",
    "node-tesseract-ocr": "^2.2.1",
    "nodemailer": "^8.0.7",
    "officeparser": "^7.0.3",
    "openai": "^6.39.0",
    "otpauth": "^9.5.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pdf2pic": "^3.2.0",
    "pdfjs-dist": "^5.7.284",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "qs": "^6.15.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.1",
    "tslib": "^2.8.1",
    "turndown": "^7.2.4",
    "web-push": "^3.6.7",
    "xlsx-republish": "^0.20.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/testing": "^11.1.23",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mailparser": "^3.4.6",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/uuid": "^10.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/qs": "^6.15.1",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "commander": "^14.0.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.7"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "nestjs",
    "jsonapi",
    "neo4j",
    "redis",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/carlonicora/nestjs-neo4jsonapi"
  },
  "publishConfig": {
    "access": "public"
  },
